-- Variáveis de Elite
local Config = {
    AutoKill = false,
    SilentAim = false,
    Fly = false,
    WalkSpeed = 16,
    JumpPower = 50
}

-- Aba de Combate Profissional
local CombatTab = Window:CreateTab("Combate Elite", 4483362458)

CombatTab:CreateSection("Funções Destrutivas")

CombatTab:CreateToggle({
   Name = "Silent Aim (100% Hitrate)",
   CurrentValue = false,
   Callback = function(Value)
      Config.SilentAim = Value
      -- Lógica de redirecionamento de projéteis aqui
   end,
})

CombatTab:CreateToggle({
   Name = "Kill Aura (Mata ao Redor)",
   CurrentValue = false,
   Callback = function(Value)
      Config.AutoKill = Value
      task.spawn(function()
          while Config.AutoKill do
              for _, v in pairs(game:GetService("Players"):GetPlayers()) do
                  if v ~= game.Players.LocalPlayer and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                      local dist = (v.Character.HumanoidRootPart.Position - game.Players.LocalPlayer.Character.HumanoidRootPart.Position).Magnitude
                      if dist < 20 then
                          -- Simula o dano (depende do jogo)
                          v.Character.Humanoid:TakeDamage(10) 
                      end
                  end
              end
              task.wait(0.5)
          end
      end)
   end,
})

-- Aba de Movimentação (Estilo ERC/Admin)
